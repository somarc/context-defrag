{
  "name": "context-defrag",
  "version": "1.0.0",
  "description": "Mine your LLM session histories (Claude, Codex, Cursor) into a structured Obsidian knowledge vault",
  "main": "cli/defrag.js",
  "bin": {
    "context-defrag": "./cli/defrag.js",
    "defrag": "./cli/defrag.js"
  },
  "files": [
    "cli/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node cli/defrag.js",
    "test": "node cli/defrag.js --dry-run --verbose"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "glob": "^10.3.10"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "preferGlobal": false,
  "keywords": [
    "llm",
    "claude",
    "codex",
    "cursor",
    "obsidian",
    "knowledge-management",
    "cli",
    "context",
    "notes",
    "markdown"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/somarc/context-defrag.git"
  }
}
